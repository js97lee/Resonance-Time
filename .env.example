# 네이버 클라우드 Maps — Static Map (raster-cors, Referer)
# 문서: https://api.ncloud-docs.com/docs/ko/application-maps-overview
# 콘솔 Application 등록 후 Client ID 발급, Web 서비스 URL에 배포 도메인 입력
# 미설정 시 방문 안내는 public/assets/visit-map.png 사용
# VITE_NCP_MAP_CLIENT_ID=your-ncp-client-id
# 중심 좌표 WGS84 경도,위도 (기본: 언커먼 갤러리 인근)
# VITE_VISIT_MAP_CENTER=127.0286,37.5085

# FormSubmit.co 사용 중 - 별도 설정 없음 (100% 무료)
# 첫 제출 시 studio.realday@gmail.com 으로 확인 메일 옴 → 클릭해 활성화

# 이메일·QR 링크에 쓰일 공개 URL (배포 도메인, 끝에 / 없이)
# VITE_PUBLIC_SITE_URL=https://js97lee.github.io/Resonance-Time

# /revp 초대·등록 목록 열람용 비밀번호 (미설정 시 개발용으로 비번 없이 열림)
# VITE_REVP_SECRET=your-strong-secret
